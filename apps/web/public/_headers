# Cloudflare Pages security headers (本番強化版)
# https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site
  X-DNS-Prefetch-Control: off
  X-Permitted-Cross-Domain-Policies: none
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://api.line-port.com https://staging-api.line-port.com https://line-harness-test.reoyakyu428z.workers.dev https://*.workers.dev; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests; report-uri https://api.line-port.com/api/csp-report

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/_next/image*
  Cache-Control: public, max-age=86400

# ロゴ・アイコン・favicon は 1 週間 + stale-while-revalidate (背景更新)
/logo.png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/favicon-*.png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/icon-*.png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/apple-touch-icon.png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# API key などのシークレットが入る可能性のあるページはキャッシュさせない
/client/*
  Cache-Control: no-store, must-revalidate
/login
  Cache-Control: no-store, must-revalidate
